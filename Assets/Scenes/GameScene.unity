    - target: {fileID: 2118764960772319183, guid: 727a86d465113fb4e8336b11b0aec4d5, type: 3}
      propertyPath: m_text
      value: "<b>\u0413\u043B\u0430\u0432\u043D\u0430\u044F \u0446\u0435\u043B\u044C:</b>
        \u0417\u0430\u0449\u0438\u0442\u0438\u0442\u044C \u0437\u0430\u043C\u043E\u043A
        \u043E\u0442 \u043D\u0430\u0441\u0442\u0443\u043F\u0430\u044E\u0449\u0438\u0445
        \u0432\u043E\u043B\u043D \u043C\u043E\u043D\u0441\u0442\u0440\u043E\u0432.\\n\u2022
        \u0418\u0433\u0440\u0430 \u043D\u0430\u0447\u043D\u0451\u0442\u0441\u044F,
        \u043A\u0430\u043A \u0442\u043E\u043B\u044C\u043A\u043E \u0432\u044B \u0440\u0430\u0437\u043C\u0435\u0441\u0442\u0438\u0442\u0435
        \u0441\u0432\u043E\u044E <b>\u043F\u0435\u0440\u0432\u0443\u044E \u043F\u043E\u0441\u0442\u0440\u043E\u0439\u043A\u0443</b>.\\n\u2022
        \u0423\u043D\u0438\u0447\u0442\u043E\u0436\u0430\u0439\u0442\u0435 \u0432\u0440\u0430\u0433\u043E\u0432,
        \u043F\u043E\u043B\u0443\u0447\u0430\u0439\u0442\u0435 \u0437\u0430 \u043D\u0438\u0445
        <b>\u0434\u0435\u043D\u044C\u0433\u0438</b> \u0438 \u0442\u0440\u0430\u0442\u044C\u0442\u0435
        \u0438\u0445 \u043D\u0430 \u043E\u0431\u043E\u0440\u043E\u043D\u0443.\\n\u2022
        \u0425\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u0438\u0441\u0442\u0438\u043A\u0438
        \u043E\u0431\u044A\u0435\u043A\u0442\u043E\u0432 \u043C\u043E\u0436\u043D\u043E
        \u0443\u0432\u0438\u0434\u0435\u0442\u044C \u043F\u0440\u0438 <i>\u043D\u0430\u0432\u0435\u0434\u0435\u043D\u0438\u0438
        \u043A\u0443\u0440\u0441\u043E\u0440\u0430</i> \u0432 \u043C\u0430\u0433\u0430\u0437\u0438\u043D\u0430\u0445."
      objectReference: {fileID: 0}
